#######################################
# Service configuration               #
#######################################
#
# Ports and logging for the tile service.
# Adjust HTTP_PORT if running multiple
# services on your dev machine.
#

HTTP_PORT=8080

LOG_LEVEL=info

#######################################
# Tile storage paths                   #
#######################################
#
# TILES_PATH (required): Directory containing
# .mbtiles files to serve. Supports ~ expansion.
#
# STYLES_PATH (optional): Directory containing
# map style JSON files. If not set, only
# default style names are advertised.
#

TILES_PATH=~/dev/swayrider/localdata/tiles

STYLES_PATH=~/dev/swayrider/swayrider/assets/map/styles

#######################################
# Compression settings                 #
#######################################
#
# COMPRESSION_ENABLED: Enable HTTP gzip
# compression for tile responses.
#
# COMPRESSION_CACHE_SIZE: Maximum number
# of compressed tiles to hold in memory.
#

COMPRESSION_ENABLED=true

COMPRESSION_CACHE_SIZE=1000

#######################################
# Disk cache settings                 #
#######################################
#
# DISK_CACHE_ENABLED: Enable persistent
# disk cache for tiles (two-tier caching).
#
# DISK_CACHE_PATH: Directory for disk cache.
# Supports ~ expansion.
#
# DISK_CACHE_MAX_FILES: Maximum number of
# cached tile files.
#

DISK_CACHE_ENABLED=false

DISK_CACHE_PATH=~/dev/swayrider/localdata/cache

DISK_CACHE_MAX_FILES=100000

#######################################
# Public service URL                 #
#######################################
#
# SERVICE_HOST: Public hostname for the
# service (used in style tile URLs).
#
# SERVICE_PORT: Public port (optional;
# omit for standard ports 80/443).
#
# SERVICE_PREFIX: URL prefix for tile
# endpoints (e.g. /v1/tiles).
#

SERVICE_HOST=https://tiles.example.com

SERVICE_PORT=

SERVICE_PREFIX=/v1/tiles